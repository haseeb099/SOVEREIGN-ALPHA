# Sovereign-Alpha environment variables
# Copy to .env at the repository root. Never commit .env.

# --- Required for AI analysis ---
# Cerebras API key: https://cloud.cerebras.ai
CEREBRAS_API_KEY=your_cerebras_api_key_here
# Model id used by the agent pipeline
CEREBRAS_MODEL=gemma-4-31b

# --- Data stores (local defaults match docker-compose) ---
REDIS_URL=redis://localhost:6379
DATABASE_URL=postgresql://sovereign:sovereign@localhost:5433/sovereign_alpha
# Set false so the API runs migrations and enables Postgres-backed features (portfolio, library, workspaces).
# Use true only when Docker/Postgres is unavailable and you need the API to start without DB.
SKIP_DB_INIT=false
# Set true only when Postgres is intentionally offline (API starts without DB features)
SKIP_DB_INIT=false

# --- Market data ---
# Polygon REST API — live quotes, search, history; yfinance/ccxt when unset
POLYGON_API_KEY=
POLYGON_BASE_URL=https://api.polygon.io

# Massive.com S3 flat files — bulk historical CSV/GZIP (separate from POLYGON_API_KEY)
# Get S3 keys from: https://massive.com/dashboard
MASSIVE_S3_ACCESS_KEY_ID=
MASSIVE_S3_SECRET_ACCESS_KEY=
MASSIVE_S3_ENDPOINT=https://files.massive.com
MASSIVE_S3_BUCKET=flatfiles
# Optional fallbacks for news and fundamentals
NEWS_API_KEY=
ALPHA_VANTAGE_KEY=
# Redis TTL seconds for market cache
MARKET_CACHE_TTL_EQUITY=15
MARKET_CACHE_TTL_CRYPTO=5
# Annual risk-free rate for Sharpe ratio (e.g. 0.045 = 4.5%)
RISK_FREE_RATE=0

# --- Embeddings (Phase 16 RAG) ---
# OpenAI text-embedding-3-small when set; hash fallback when empty
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_API_KEY=

# --- Authentication (Clerk) ---
# Leave empty for local dev without sign-in
CLERK_SECRET_KEY=
CLERK_JWKS_URL=
CLERK_ISSUER=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# --- Email and observability ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=reports@yourdomain.com
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# --- Phase 22 Enterprise ---
CLERK_ORGANIZATION_ENABLED=true
AUDIT_LOG_RETENTION_DAYS=2555
WHITE_LABEL_DEFAULT_ORG=
CUSTOM_DOMAIN_MAP=
PROMETHEUS_METRICS_ENABLED=true
ENTERPRISE_API_RATE_LIMIT=100000/month

# --- Phase 19 workflow tools ---
# Tavily web search (optional — DuckDuckGo fallback when unset)
TAVILY_API_KEY=
# Required by SEC EDGAR API — use a descriptive app name and contact email
SEC_EDGAR_USER_AGENT=Sovereign-Alpha contact@yourdomain.com
# Redis TTL for LangGraph workflow checkpoint keys
WORKFLOW_CHECKPOINT_TTL_SECONDS=3600

# --- Phase 20 research agents & watchers ---
WATCHER_ENABLED=true
WATCHER_POLL_INTERVAL_SECONDS=300
WATCHER_FORMS=10-Q,8-K,10-K,4
OPENSANCTIONS_API_URL=https://api.opensanctions.org

# --- Phase 21 Valuation Lab ---
# Monte Carlo simulation count (default 2000)
VALUATION_MC_SIMS=2000
# Redis TTL seconds for financials cache
FINANCIALS_CACHE_TTL=600
LOG_LEVEL=INFO
# Comma-separated browser origins (no wildcards in production)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,http://127.0.0.1:3000,http://127.0.0.1:8000
RATE_LIMIT_DEFAULT=120/minute
# Demo key for /api/v1/public when no DB API keys exist
DEMO_API_KEY=demo-sovereign-key

# --- Embeddings (Phase 16 RAG) ---
# OpenAI text-embedding-3-small or compatible API
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_API_KEY=
EMBEDDING_DIM=1536

# --- Phase 22 Enterprise Hardening ---
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
CLERK_ORGANIZATION_ENABLED=true
AUDIT_LOG_RETENTION_DAYS=2555
WHITE_LABEL_DEFAULT_ORG=
CUSTOM_DOMAIN_MAP={}
PROMETHEUS_METRICS_ENABLED=true
ENTERPRISE_API_RATE_LIMIT=100000/month
METRICS_AUTH_TOKEN=
# --- Phase 23 GTM Launch ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
CLERK_WEBHOOK_SECRET=
NEXT_PUBLIC_APP_URL=http://localhost:3000
DEMO_MODE=true
ENTERPRISE_SALES_EMAIL=
# Seed demo data: cd backend && python scripts/seed_demo.py

# --- Phase 23 GTM ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
STRIPE_TRIAL_DAYS=14
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
FRONTEND_URL=http://localhost:3000
CLERK_WEBHOOK_SECRET=
ENTERPRISE_SALES_EMAIL=
DEMO_MODE=false

# --- Next.js (apps/web) ---
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
NEXT_PUBLIC_WS_URL=ws://127.0.0.1:8000