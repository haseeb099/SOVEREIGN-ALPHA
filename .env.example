# Sovereign-Alpha Environment Variables
# Copy this to .env and fill in your keys
# NEVER commit .env to git

# ── Required ────────────────────────────────────────────────
# Get from: https://cloud.cerebras.ai/
CEREBRAS_API_KEY=your_cerebras_api_key_here
CEREBRAS_MODEL=gemma-4-31b

# ── Optional but recommended ─────────────────────────────────
# Get from: https://newsapi.org/ (free: 100 req/day)
NEWS_API_KEY=your_newsapi_key_here

# Get from: https://www.alphavantage.co/ (free fallback for FX data)
ALPHA_VANTAGE_KEY=your_alpha_vantage_key_here

# ── Infrastructure ───────────────────────────────────────────
# Redis — run locally with: docker run -p 6379:6379 redis:alpine
REDIS_URL=redis://localhost:6379

# PostgreSQL — for thesis history persistence (optional for hackathon)
DATABASE_URL=postgresql://sovereign:sovereign@localhost:5433/sovereign_alpha

# ── App Config ───────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO

# Comma-separated frontend origins (no wildcard). Required in production.
# Local dev defaults to localhost if unset; explicit list recommended.
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
# Production example:
# ENVIRONMENT=production
# ALLOWED_ORIGINS=https://your-frontend.vercel.app
# LOG_LEVEL=WARNING

# ── Frontend deploy (Vercel) ─────────────────────────────────
# Set in Vercel project env — used by scripts/write-frontend-config.js at build
# SOVEREIGN_ALPHA_API_URL=https://sovereign-alpha-api.onrender.com
