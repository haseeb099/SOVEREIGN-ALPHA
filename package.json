{
  "name": "sovereign-alpha",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @sovereign/web dev",
    "dev:api": "cd backend && uvicorn main:app --reload --port 8000",
    "dev:all": "concurrently -k -n api,web -c blue,green \"pnpm dev:api\" \"pnpm dev\"",
    "dev:stack": "docker compose up -d redis postgres && pnpm dev:all",
    "build": "pnpm --filter @sovereign/web build",
    "typecheck": "pnpm --filter @sovereign/web typecheck",
    "lint": "pnpm --filter @sovereign/web lint"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "turbo": "^2.10.0"
  },
  "packageManager": "pnpm@10.33.2"
}
